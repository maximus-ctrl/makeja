VITE_APP_NAME=Makeja
VITE_API_BASE_URL=http://localhost:8000/api

# Frontend feature switches. These are public because Vite exposes VITE_* values to browser code.
VITE_ENABLE_MAPS=true
VITE_ENABLE_MPESA_STK=true
VITE_ENABLE_SUBSCRIPTIONS=false
VITE_ENABLE_BLUE_TICK=false
VITE_ENABLE_WHATSAPP=true

# Public browser key only. Do not put Daraja/Supabase service secrets here.
VITE_GOOGLE_MAPS_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
